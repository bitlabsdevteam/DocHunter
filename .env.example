# -------------------------------
# DocHunter environment template
# -------------------------------
# Never commit real secrets. Copy to .env locally.

NODE_ENV=development
PORT=3000

# AI model routing (OpenAI default path)
DEFAULT_MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Research / retrieval
RESEARCH_ENGINE=perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_TIMEOUT_MS=35000
PERPLEXITY_MAX_RETRIES=2

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email / notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Vercel (read local key from your machine env file when needed)
VERCEL_API_KEY=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# MCP servers
MCP_DIRECTORY_SERVER_URL=
MCP_BOOKING_SERVER_URL=
